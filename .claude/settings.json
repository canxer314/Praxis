{
  "permissions": {
    "allow": [
      "mcp__codegraph__codegraph_explore",
      "mcp__codegraph__codegraph_search",
      "mcp__codegraph__codegraph_node",
      "mcp__codegraph__codegraph_callers",
      "mcp__codegraph__codegraph_callees",
      "mcp__codegraph__codegraph_impact",
      "mcp__codegraph__codegraph_files",
      "mcp__codegraph__codegraph_status",
      "PowerShell"
    ],
    "deny": [
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "try { & \"$env:USERPROFILE/.bun/bin/bun.exe\" $env:CLAUDE_PROJECT_DIR/dist/praxis-hook.js session_start \"$env:CLAUDE_SESSION_ID\" 2>$null } catch {} ; exit 0",
            "shell": "powershell"
          }
        ]
      }
    ],
    "UserPromptExpansion": [],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "try { & \"$env:USERPROFILE/.bun/bin/bun.exe\" $env:CLAUDE_PROJECT_DIR/dist/praxis-hook.js message_received \"$env:CLAUDE_SESSION_ID\" 2>$null } catch {} ; exit 0",
            "shell": "powershell",
            "timeout": 45
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "try { & \"$env:USERPROFILE/.bun/bin/bun.exe\" $env:CLAUDE_PROJECT_DIR/dist/praxis-hook.js agent_end \"$env:CLAUDE_SESSION_ID\" 2>$null } catch {} ; exit 0",
            "shell": "powershell"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Skill",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR/.claude/hooks/check-gstack.sh\""
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "superpowers@claude-plugins-official": true
  }
}
